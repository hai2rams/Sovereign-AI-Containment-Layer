# API listen port (4000 is often used by the legacy reference project)
PORT=4100

# Terminal 3 developer key
# https://docs.terminal3.io/developers/adk/get-started/prerequisites/request-test-tokens
T3N_API_KEY=

# testnet | production
T3N_ENVIRONMENT=testnet

# Numeric T3N contract id (trust anchor). Not an Ethereum address.
# Legacy reference deployment from t3-compliance-gateway (testnet): 15
T3N_CONTRACT_ID=

# Contract registration metadata (used when registering a new TEE contract)
T3N_CONTRACT_TAIL=containment-trust-anchor-v1
T3N_CONTRACT_VERSION=0.1.0

# Path to WASM bytes when running contract registration scripts
T3N_CONTRACT_WASM_PATH=
